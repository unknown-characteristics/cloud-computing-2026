# Local-dev defaults. In Azure App Service these come from "Application settings"
# (and from Key Vault references for the sensitive ones).

# JWT
SECRET_KEY_NAME=USERS-JWT-KEY
ALGORITHM=RS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
JWT_AUDIENCE=comparena-users

# Azure resources
KEY_VAULT_URL=https://comparena-kv.vault.azure.net
SERVICE_BUS_NAMESPACE=comparena-bus.servicebus.windows.net
SERVICE_BUS_TOPIC=users-events
SERVICE_BUS_SUBSCRIPTION=users-service

# Key Vault secret holding the dotenv-style DB credentials
DB_CREDS_SECRET=USERS-DB-CREDS

# Cosmos DB (replaces GCP Datastore)
COSMOS_ENDPOINT=https://comparena-cosmos.documents.azure.com:443/
COSMOS_DATABASE=comparena
